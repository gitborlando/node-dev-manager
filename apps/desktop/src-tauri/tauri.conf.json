{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Node Dev Manager",
  "version": "0.1.0",
  "identifier": "com.gitborlando.node-dev-mgr",
  "build": {
    "beforeDevCommand": "pnpm dev:tauri",
    "beforeBuildCommand": "pnpm build",
    "devUrl": "http://127.0.0.1:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Node Dev Manager",
        "width": 1360,
        "height": 860,
        "minWidth": 1120,
        "minHeight": 720
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": false,
    "targets": "all",
    "icon": []
  }
}
